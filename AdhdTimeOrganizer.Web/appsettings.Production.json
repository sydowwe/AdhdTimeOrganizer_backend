{
  "Serilog": {
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "Path": "logs/prod-log-.txt",
          "RollingInterval": "Day",
          "RetainedFileCountLimit": 30
        }
      },
      {
        "Name": "PostgreSQL",
        "Args": {
          "ConnectionString": "Host=your-prod-db;Database=logs;Username=loguser;Password=yourpassword",
          "TableName": "api_logs"
        }
      }
    ],
    "MinimumLevel": "Warning"
  }
}